# KV store (Vercel KV or a standalone Upstash Redis both work — same REST
# API) — this app's own store, separate from any storefront's.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Password for /admin (subscribers, campaigns, automations).
ADMIN_PASSWORD=

# This deployment's own URL — used to build unsubscribe links.
# e.g. https://mail.smellsiconic.com
NEXT_PUBLIC_BASE_URL=

# Comma-separated list of origins allowed to call POST /api/email/subscribe
# from their own page JS (the storefront(s) using this deployment).
# e.g. https://smellsiconic.com,https://smells-iconic.vercel.app
ALLOWED_ORIGINS=

# Where /api/email/confirm sends people after confirming, so the "you're
# in" message shows in-context on the storefront rather than here.
# e.g. https://smellsiconic.com
SITE_REDIRECT_URL=

# Resend — see DEPLOYMENT.md for the full setup: domain verification
# (DKIM/SPF), API key, bounce/complaint webhook.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=
# Signing secret Resend gives you when you create the webhook endpoint
# (Dashboard → Webhooks) — verifies /api/email/resend-webhook requests
# actually came from Resend. Starts with "whsec_".
RESEND_WEBHOOK_SECRET=

# Random string that authenticates calls to /api/cron/automations.
CRON_SECRET=

# Shopify Admin API — a Custom App created via Shopify's Dev Dashboard,
# authenticated with the OAuth client-credentials grant (Shopify retired
# permanent Admin API tokens for new custom apps as of Jan 1, 2026).
# SHOPIFY_CLIENT_ID / SHOPIFY_CLIENT_SECRET are exchanged for a short-lived
# access token automatically — see DEPLOYMENT.md for creating the app, its
# required scopes, and the webhook subscriptions that point at
# /api/shopify/webhook.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_API_VERSION=2024-10
SHOPIFY_WEBHOOK_SECRET=
